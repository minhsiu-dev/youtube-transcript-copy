{
  "name": "yt-transcript-copier",
  "version": "0.1.0",
  "private": true,
  "description": "Copy YouTube video transcripts to clipboard with one click.",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/popup/popup.css -o dist/popup/popup.css --minify",
    "build:js": "node esbuild.config.mjs",
    "build": "npm run build:css && npm run build:js",
    "watch": "concurrently -k -n css,js \"tailwindcss -i src/popup/popup.css -o dist/popup/popup.css --watch\" \"node esbuild.config.mjs --watch\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.{ts,html,css,json}' 'tests/**/*.ts'",
    "icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/chrome": "^0.0.270",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
